{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/guard_paths.py"],
            "timeout": 15,
            "statusMessage": "path guard"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/gate_on_commit.py"],
            "timeout": 300,
            "statusMessage": "commit gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/format_py.py"],
            "timeout": 30,
            "statusMessage": "ruff format"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/inject_core_rules.py"],
            "timeout": 15,
            "statusMessage": "inject core-rules"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/inject_reuse_pointer.py"],
            "timeout": 15,
            "statusMessage": "reuse pointer"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/inject_convention_pointer.py"],
            "timeout": 15,
            "statusMessage": "convention pointer"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/check_reuse_pointers.py"],
            "timeout": 30,
            "statusMessage": "reuse pointer check"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/check_convention_pointers.py"],
            "timeout": 30,
            "statusMessage": "convention pointer check"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/remind_evaluator.py"],
            "timeout": 20,
            "statusMessage": "evaluator reminder"
          }
        ]
      }
    ]
  }
}
