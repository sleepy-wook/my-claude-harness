{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/guard_paths.py"],
            "timeout": 15,
            "statusMessage": "path guard"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/format_py.py"],
            "timeout": 30,
            "statusMessage": "ruff format"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/inject_core_rules.py"],
            "timeout": 15,
            "statusMessage": "inject core-rules"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/inject_reuse_pointer.py"],
            "timeout": 15,
            "statusMessage": "reuse pointer"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/evaluate_gate.py"],
            "timeout": 300,
            "statusMessage": "auto-evaluate gate"
          },
          {
            "type": "command",
            "command": "python",
            "args": ["{HOOKS_DIR}/check_reuse_pointers.py"],
            "timeout": 30,
            "statusMessage": "reuse pointer check"
          }
        ]
      }
    ]
  }
}
